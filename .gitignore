# ── Python ──────────────────────────────────────────────────────
venv/
.venv/
exdav_env/
env/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.coverage
htmlcov/

# ── Node / frontend ────────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/build/
frontend/coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── App runtime artefacts ──────────────────────────────────────
# Keep the directories (via .gitkeep) but never commit their contents.
backend/uploads/*
!backend/uploads/.gitkeep
outputs/*
!outputs/.gitkeep
reports/*
!reports/.gitkeep

# ── Research data (HUGE — never commit) ────────────────────────
dataset/
demo/outputs/
notebooks/.ipynb_checkpoints/

# ── Local env / secrets ────────────────────────────────────────
.env
.env.*
!.env.example
frontend/.env
frontend/.env.local
frontend/.env.production
!frontend/.env.example

# ── Editor / OS ────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Docker / build scratch ─────────────────────────────────────
*.log
*.pid
