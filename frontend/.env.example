# Copy this file to `.env` (local) or `.env.production` (build-time) and
# point it at the deployed Ex-DAV backend URL — no trailing slash.
#
# Local backend (default when the variable is unset):
#   REACT_APP_BACKEND_URL=http://127.0.0.1:8000
#
# Deployed backend examples:
#   REACT_APP_BACKEND_URL=https://exdav-backend.onrender.com
#   REACT_APP_BACKEND_URL=https://exdav-backend.up.railway.app

REACT_APP_BACKEND_URL=http://127.0.0.1:8000
