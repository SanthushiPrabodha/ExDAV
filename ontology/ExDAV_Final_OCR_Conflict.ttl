###  http://www.co-ode.org/ontologies/ont.owl#RegulatoryGuideline
<http://www.co-ode.org/ontologies/ont.owl#RegulatoryGuideline> rdf:type owl:Class .


###  http://www.co-ode.org/ontologies/ont.owl#RegulatoryRequirement
<http://www.co-ode.org/ontologies/ont.owl#RegulatoryRequirement> rdf:type owl:Class .


###  http://www.co-ode.org/ontologies/ont.owl#RegulatorySection
<http://www.co-ode.org/ontologies/ont.owl#RegulatorySection> rdf:type owl:Class .


###  http://www.co-ode.org/ontologies/ont.owl#RegulatoryStatus
<http://www.co-ode.org/ontologies/ont.owl#RegulatoryStatus> rdf:type owl:Class ;
                                                            rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                              owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#assignedTo> ;
                                                                              owl:someValuesFrom <http://www.co-ode.org/ontologies/ont.owl#AuthenticityAssesment>
                                                                            ] .


###  http://www.co-ode.org/ontologies/ont.owl#RegulatoryViolation
<http://www.co-ode.org/ontologies/ont.owl#RegulatoryViolation> rdf:type owl:Class ;
                                                               rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                                 owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#triggeredBy> ;
                                                                                 owl:someValuesFrom <http://www.co-ode.org/ontologies/ont.owl#Conflict>
                                                                               ] ,
                                                                               [ rdf:type owl:Restriction ;
                                                                                 owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#violates> ;
                                                                                 owl:someValuesFrom <http://www.co-ode.org/ontologies/ont.owl#RegulatoryRequirement>
                                                                               ] .


