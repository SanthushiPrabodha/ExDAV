@prefix : <http://www.exdav.org/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.exdav.org/ontology> .

<http://www.exdav.org/ontology> rdf:type owl:Ontology .

#################################################################
#    Annotation properties
#################################################################

###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
<http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.co-ode.org/ontologies/ont.owl#arisesFrom
<http://www.co-ode.org/ontologies/ont.owl#arisesFrom> rdf:type owl:ObjectProperty ;
                                                      rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#Conflict> ;
                                                      rdfs:range <http://www.co-ode.org/ontologies/ont.owl#Evidence> .


###  http://www.co-ode.org/ontologies/ont.owl#assesses
<http://www.co-ode.org/ontologies/ont.owl#assesses> rdf:type owl:ObjectProperty ;
                                                    rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#AuthenticityAssesment> ;
                                                    rdfs:range <http://www.co-ode.org/ontologies/ont.owl#Evidence> .


###  http://www.co-ode.org/ontologies/ont.owl#assignedTo
<http://www.co-ode.org/ontologies/ont.owl#assignedTo> rdf:type owl:ObjectProperty .


###  http://www.co-ode.org/ontologies/ont.owl#containsClaim
<http://www.co-ode.org/ontologies/ont.owl#containsClaim> rdf:type owl:ObjectProperty .


###  http://www.co-ode.org/ontologies/ont.owl#derivedFrom
<http://www.co-ode.org/ontologies/ont.owl#derivedFrom> rdf:type owl:ObjectProperty .


###  http://www.co-ode.org/ontologies/ont.owl#describes
<http://www.co-ode.org/ontologies/ont.owl#describes> rdf:type owl:ObjectProperty .


###  http://www.co-ode.org/ontologies/ont.owl#detectedIn
<http://www.co-ode.org/ontologies/ont.owl#detectedIn> rdf:type owl:ObjectProperty .


###  http://www.co-ode.org/ontologies/ont.owl#detectsConflict
<http://www.co-ode.org/ontologies/ont.owl#detectsConflict> rdf:type owl:ObjectProperty ;
                                                           rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#AuthenticityAssesment> ;
                                                           rdfs:range <http://www.co-ode.org/ontologies/ont.owl#Conflict> .


###  http://www.co-ode.org/ontologies/ont.owl#hasAssessment
<http://www.co-ode.org/ontologies/ont.owl#hasAssessment> rdf:type owl:ObjectProperty ;
                                                         rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#DrugProduct> ;
                                                         rdfs:range <http://www.co-ode.org/ontologies/ont.owl#AuthenticityAssesment> .


###  http://www.co-ode.org/ontologies/ont.owl#hasClaim
<http://www.co-ode.org/ontologies/ont.owl#hasClaim> rdf:type owl:ObjectProperty ;
                                                    rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#Drug> ;
                                                    rdfs:range <http://www.co-ode.org/ontologies/ont.owl#Claim> .


###  http://www.co-ode.org/ontologies/ont.owl#hasConflict
<http://www.co-ode.org/ontologies/ont.owl#hasConflict> rdf:type owl:ObjectProperty ;
                                                       rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#DrugProduct> ;
                                                       rdfs:range <http://www.co-ode.org/ontologies/ont.owl#Conflict> .


###  http://www.co-ode.org/ontologies/ont.owl#hasDrug
<http://www.co-ode.org/ontologies/ont.owl#hasDrug> rdf:type owl:ObjectProperty ;
                                                   rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#AuthenticityAssesment> ;
                                                   rdfs:range <http://www.co-ode.org/ontologies/ont.owl#Drug> ,
                                                              <http://www.co-ode.org/ontologies/ont.owl#Evidence> ,
                                                              <http://www.co-ode.org/ontologies/ont.owl#RegulatoryStatus> .


###  http://www.co-ode.org/ontologies/ont.owl#hasEvidence
<http://www.co-ode.org/ontologies/ont.owl#hasEvidence> rdf:type owl:ObjectProperty ;
                                                       rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#DrugProduct> ;
                                                       rdfs:range <http://www.co-ode.org/ontologies/ont.owl#Evidence> .


###  http://www.co-ode.org/ontologies/ont.owl#hasImage
<http://www.co-ode.org/ontologies/ont.owl#hasImage> rdf:type owl:ObjectProperty ;
                                                    rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#Drug> ;
                                                    rdfs:range <http://www.co-ode.org/ontologies/ont.owl#DrugImage> .


###  http://www.co-ode.org/ontologies/ont.owl#hasLabel
<http://www.co-ode.org/ontologies/ont.owl#hasLabel> rdf:type owl:ObjectProperty ;
                                                    rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#Drug> ;
                                                    rdfs:range <http://www.co-ode.org/ontologies/ont.owl#Label> .


###  http://www.co-ode.org/ontologies/ont.owl#hasLabelElement
<http://www.co-ode.org/ontologies/ont.owl#hasLabelElement> rdf:type owl:ObjectProperty ;
                                                           rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#Label> ;
                                                           rdfs:range <http://www.co-ode.org/ontologies/ont.owl#LabelElement> .


###  http://www.co-ode.org/ontologies/ont.owl#hasOutcome
<http://www.co-ode.org/ontologies/ont.owl#hasOutcome> rdf:type owl:ObjectProperty ;
                                                      rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#DrugProduct> ;
                                                      rdfs:range <http://www.co-ode.org/ontologies/ont.owl#VerificationOutcome> .


###  http://www.co-ode.org/ontologies/ont.owl#hasRegulatoryStatus
<http://www.co-ode.org/ontologies/ont.owl#hasRegulatoryStatus> rdf:type owl:ObjectProperty ;
                                                               rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#Drug> ;
                                                               rdfs:range <http://www.co-ode.org/ontologies/ont.owl#RegulatoryStatus> .


###  http://www.co-ode.org/ontologies/ont.owl#hasSource
<http://www.co-ode.org/ontologies/ont.owl#hasSource> rdf:type owl:ObjectProperty ;
                                                     rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#Evidence> ;
                                                     rdfs:range <http://www.co-ode.org/ontologies/ont.owl#EvidenceSource> .


###  http://www.co-ode.org/ontologies/ont.owl#hasVisualEvidence
<http://www.co-ode.org/ontologies/ont.owl#hasVisualEvidence> rdf:type owl:ObjectProperty ;
                                                             rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#Claim> ;
                                                             rdfs:range <http://www.co-ode.org/ontologies/ont.owl#DrugImage> .


###  http://www.co-ode.org/ontologies/ont.owl#isClaimOn
<http://www.co-ode.org/ontologies/ont.owl#isClaimOn> rdf:type owl:ObjectProperty .


###  http://www.co-ode.org/ontologies/ont.owl#isLabelOf
<http://www.co-ode.org/ontologies/ont.owl#isLabelOf> rdf:type owl:ObjectProperty .


###  http://www.co-ode.org/ontologies/ont.owl#isPartOf
<http://www.co-ode.org/ontologies/ont.owl#isPartOf> rdf:type owl:ObjectProperty .


###  http://www.co-ode.org/ontologies/ont.owl#mayCause
<http://www.co-ode.org/ontologies/ont.owl#mayCause> rdf:type owl:ObjectProperty .


###  http://www.co-ode.org/ontologies/ont.owl#producesStatus
<http://www.co-ode.org/ontologies/ont.owl#producesStatus> rdf:type owl:ObjectProperty ;
                                                          rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#Drug> ;
                                                          rdfs:range <http://www.co-ode.org/ontologies/ont.owl#RegulatoryStatus> .


###  http://www.co-ode.org/ontologies/ont.owl#provides
<http://www.co-ode.org/ontologies/ont.owl#provides> rdf:type owl:ObjectProperty .


###  http://www.co-ode.org/ontologies/ont.owl#refersToGuideline
<http://www.co-ode.org/ontologies/ont.owl#refersToGuideline> rdf:type owl:ObjectProperty ;
                                                             rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#AuthenticityAssesment> ;
                                                             rdfs:range <http://www.co-ode.org/ontologies/ont.owl#RegulatoryGuideline> .


###  http://www.co-ode.org/ontologies/ont.owl#support
<http://www.co-ode.org/ontologies/ont.owl#support> rdf:type owl:ObjectProperty .


###  http://www.co-ode.org/ontologies/ont.owl#treats
<http://www.co-ode.org/ontologies/ont.owl#treats> rdf:type owl:ObjectProperty ;
                                                  rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#DrugProduct> ;
                                                  rdfs:range <http://www.co-ode.org/ontologies/ont.owl#Disease> .


###  http://www.co-ode.org/ontologies/ont.owl#triggeredBy
<http://www.co-ode.org/ontologies/ont.owl#triggeredBy> rdf:type owl:ObjectProperty .


###  http://www.co-ode.org/ontologies/ont.owl#usedIn
<http://www.co-ode.org/ontologies/ont.owl#usedIn> rdf:type owl:ObjectProperty .


###  http://www.co-ode.org/ontologies/ont.owl#usesEvidence
<http://www.co-ode.org/ontologies/ont.owl#usesEvidence> rdf:type owl:ObjectProperty ;
                                                        rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#Drug> ;
                                                        rdfs:range <http://www.co-ode.org/ontologies/ont.owl#Evidence> .


###  http://www.co-ode.org/ontologies/ont.owl#violates
<http://www.co-ode.org/ontologies/ont.owl#violates> rdf:type owl:ObjectProperty .


###  http://www.co-ode.org/ontologies/ont.owl#violatesGuideline
<http://www.co-ode.org/ontologies/ont.owl#violatesGuideline> rdf:type owl:ObjectProperty ;
                                                             rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#Drug> ;
                                                             rdfs:range <http://www.co-ode.org/ontologies/ont.owl#RegulatorySection> .


###  http://www.co-ode.org/ontologies/ont.owl#violatesSection
<http://www.co-ode.org/ontologies/ont.owl#violatesSection> rdf:type owl:ObjectProperty ;
                                                           rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#Claim> ;
                                                           rdfs:range <http://www.co-ode.org/ontologies/ont.owl#RegulatorySection> .


#################################################################
#    Data properties
#################################################################

###  http://www.co-ode.org/ontologies/ont.owl#authenticityClass
<http://www.co-ode.org/ontologies/ont.owl#authenticityClass> rdf:type owl:DatatypeProperty ;
                                                             rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#DrugImage> ;
                                                             rdfs:range xsd:string .


###  http://www.co-ode.org/ontologies/ont.owl#claimText
<http://www.co-ode.org/ontologies/ont.owl#claimText> rdf:type owl:DatatypeProperty .


###  http://www.co-ode.org/ontologies/ont.owl#claimType
<http://www.co-ode.org/ontologies/ont.owl#claimType> rdf:type owl:DatatypeProperty .


###  http://www.co-ode.org/ontologies/ont.owl#confidenceScore
<http://www.co-ode.org/ontologies/ont.owl#confidenceScore> rdf:type owl:DatatypeProperty ;
                                                           rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#Evidence> ;
                                                           rdfs:range xsd:double .


###  http://www.co-ode.org/ontologies/ont.owl#description
<http://www.co-ode.org/ontologies/ont.owl#description> rdf:type owl:DatatypeProperty .


###  http://www.co-ode.org/ontologies/ont.owl#dosageForm
<http://www.co-ode.org/ontologies/ont.owl#dosageForm> rdf:type owl:DatatypeProperty ;
                                                      rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#Drug> ;
                                                      rdfs:range xsd:string .


###  http://www.co-ode.org/ontologies/ont.owl#drugName
<http://www.co-ode.org/ontologies/ont.owl#drugName> rdf:type owl:DatatypeProperty ;
                                                    rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#Drug> ;
                                                    rdfs:range xsd:string .


###  http://www.co-ode.org/ontologies/ont.owl#evidenceType
<http://www.co-ode.org/ontologies/ont.owl#evidenceType> rdf:type owl:DatatypeProperty ;
                                                        rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#Evidence> ;
                                                        rdfs:range xsd:string .


###  http://www.co-ode.org/ontologies/ont.owl#imageID
<http://www.co-ode.org/ontologies/ont.owl#imageID> rdf:type owl:DatatypeProperty ;
                                                   rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#DrugImage> ;
                                                   rdfs:range xsd:string .


###  http://www.co-ode.org/ontologies/ont.owl#imagePath
<http://www.co-ode.org/ontologies/ont.owl#imagePath> rdf:type owl:DatatypeProperty ;
                                                     rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#DrugImage> ;
                                                     rdfs:range xsd:string .


###  http://www.co-ode.org/ontologies/ont.owl#packageSize
<http://www.co-ode.org/ontologies/ont.owl#packageSize> rdf:type owl:DatatypeProperty ;
                                                       rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#Drug> ;
                                                       rdfs:range xsd:string .


###  http://www.co-ode.org/ontologies/ont.owl#pageNumber
<http://www.co-ode.org/ontologies/ont.owl#pageNumber> rdf:type owl:DatatypeProperty .


###  http://www.co-ode.org/ontologies/ont.owl#riskScore
<http://www.co-ode.org/ontologies/ont.owl#riskScore> rdf:type owl:DatatypeProperty ;
                                                     rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#AuthenticityAssesment> ;
                                                     rdfs:range xsd:double .


###  http://www.co-ode.org/ontologies/ont.owl#sectionNumber
<http://www.co-ode.org/ontologies/ont.owl#sectionNumber> rdf:type owl:DatatypeProperty .


###  http://www.co-ode.org/ontologies/ont.owl#strength
<http://www.co-ode.org/ontologies/ont.owl#strength> rdf:type owl:DatatypeProperty ;
                                                    rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#Drug> ;
                                                    rdfs:range xsd:string .


###  http://www.co-ode.org/ontologies/ont.owl#verdict
<http://www.co-ode.org/ontologies/ont.owl#verdict> rdf:type owl:DatatypeProperty ;
                                                   rdfs:domain <http://www.co-ode.org/ontologies/ont.owl#AuthenticityAssesment> ;
                                                   rdfs:range xsd:string .


#################################################################
#    Classes
#################################################################

###  http://www.co-ode.org/ontologies/ont.owl#AuthenticDrug
<http://www.co-ode.org/ontologies/ont.owl#AuthenticDrug> rdf:type owl:Class ;
                                                         rdfs:subClassOf <http://www.co-ode.org/ontologies/ont.owl#VerificationOutcome> .


###  http://www.co-ode.org/ontologies/ont.owl#AuthenticityAssesment
<http://www.co-ode.org/ontologies/ont.owl#AuthenticityAssesment> rdf:type owl:Class ;
                                                                 rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                                   owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#hasDrug> ;
                                                                                   owl:someValuesFrom <http://www.co-ode.org/ontologies/ont.owl#Drug>
                                                                                 ] ,
                                                                                 [ rdf:type owl:Restriction ;
                                                                                   owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#producesStatus> ;
                                                                                   owl:someValuesFrom <http://www.co-ode.org/ontologies/ont.owl#RegulatoryStatus>
                                                                                 ] ,
                                                                                 [ rdf:type owl:Restriction ;
                                                                                   owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#usesEvidence> ;
                                                                                   owl:someValuesFrom <http://www.co-ode.org/ontologies/ont.owl#Evidence>
                                                                                 ] .


###  http://www.co-ode.org/ontologies/ont.owl#Cardiovascular_Disease
<http://www.co-ode.org/ontologies/ont.owl#Cardiovascular_Disease> rdf:type owl:Class ;
                                                                  rdfs:subClassOf <http://www.co-ode.org/ontologies/ont.owl#Disease> .


###  http://www.co-ode.org/ontologies/ont.owl#Claim
<http://www.co-ode.org/ontologies/ont.owl#Claim> rdf:type owl:Class ;
                                                 rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                   owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#isClaimOn> ;
                                                                   owl:someValuesFrom <http://www.co-ode.org/ontologies/ont.owl#LabelElement>
                                                                 ] ,
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#mayCause> ;
                                                                   owl:someValuesFrom <http://www.co-ode.org/ontologies/ont.owl#RegulatoryViolation>
                                                                 ] .


###  http://www.co-ode.org/ontologies/ont.owl#Compliant
<http://www.co-ode.org/ontologies/ont.owl#Compliant> rdf:type owl:Class ;
                                                     rdfs:subClassOf <http://www.co-ode.org/ontologies/ont.owl#RegulatoryStatus> ;
                                                     owl:disjointWith <http://www.co-ode.org/ontologies/ont.owl#NonCompliant> .


###  http://www.co-ode.org/ontologies/ont.owl#Conflict
<http://www.co-ode.org/ontologies/ont.owl#Conflict> rdf:type owl:Class ;
                                                    rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                      owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#arisesFrom> ;
                                                                      owl:someValuesFrom <http://www.co-ode.org/ontologies/ont.owl#Evidence>
                                                                    ] ,
                                                                    [ rdf:type owl:Restriction ;
                                                                      owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#detectedIn> ;
                                                                      owl:someValuesFrom <http://www.co-ode.org/ontologies/ont.owl#AuthenticityAssesment>
                                                                    ] .


###  http://www.co-ode.org/ontologies/ont.owl#CounterfeitDrug
<http://www.co-ode.org/ontologies/ont.owl#CounterfeitDrug> rdf:type owl:Class ;
                                                           rdfs:subClassOf <http://www.co-ode.org/ontologies/ont.owl#VerificationOutcome> .


###  http://www.co-ode.org/ontologies/ont.owl#Dermatological_Disease
<http://www.co-ode.org/ontologies/ont.owl#Dermatological_Disease> rdf:type owl:Class ;
                                                                  rdfs:subClassOf <http://www.co-ode.org/ontologies/ont.owl#Disease> .


###  http://www.co-ode.org/ontologies/ont.owl#Disease
<http://www.co-ode.org/ontologies/ont.owl#Disease> rdf:type owl:Class .


###  http://www.co-ode.org/ontologies/ont.owl#Drug
<http://www.co-ode.org/ontologies/ont.owl#Drug> rdf:type owl:Class .


###  http://www.co-ode.org/ontologies/ont.owl#DrugImage
<http://www.co-ode.org/ontologies/ont.owl#DrugImage> rdf:type owl:Class .


###  http://www.co-ode.org/ontologies/ont.owl#DrugProduct
<http://www.co-ode.org/ontologies/ont.owl#DrugProduct> rdf:type owl:Class ;
                                                       rdfs:subClassOf <http://www.co-ode.org/ontologies/ont.owl#Drug> .


###  http://www.co-ode.org/ontologies/ont.owl#Evidence
<http://www.co-ode.org/ontologies/ont.owl#Evidence> rdf:type owl:Class ;
                                                    rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                      owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#derivedFrom> ;
                                                                      owl:someValuesFrom <http://www.co-ode.org/ontologies/ont.owl#EvidenceSource>
                                                                    ] ,
                                                                    [ rdf:type owl:Restriction ;
                                                                      owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#support> ;
                                                                      owl:someValuesFrom <http://www.co-ode.org/ontologies/ont.owl#AuthenticityAssesment>
                                                                    ] .


###  http://www.co-ode.org/ontologies/ont.owl#EvidenceSource
<http://www.co-ode.org/ontologies/ont.owl#EvidenceSource> rdf:type owl:Class ;
                                                          rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                            owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#provides> ;
                                                                            owl:someValuesFrom <http://www.co-ode.org/ontologies/ont.owl#Evidence>
                                                                          ] .


###  http://www.co-ode.org/ontologies/ont.owl#Label
<http://www.co-ode.org/ontologies/ont.owl#Label> rdf:type owl:Class ;
                                                 rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                   owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#hasLabelElement> ;
                                                                   owl:someValuesFrom <http://www.co-ode.org/ontologies/ont.owl#LabelElement>
                                                                 ] ,
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#isLabelOf> ;
                                                                   owl:someValuesFrom <http://www.co-ode.org/ontologies/ont.owl#Drug>
                                                                 ] ,
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#usedIn> ;
                                                                   owl:someValuesFrom <http://www.co-ode.org/ontologies/ont.owl#AuthenticityAssesment>
                                                                 ] .


###  http://www.co-ode.org/ontologies/ont.owl#LabelElement
<http://www.co-ode.org/ontologies/ont.owl#LabelElement> rdf:type owl:Class ;
                                                        rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                          owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#containsClaim> ;
                                                                          owl:someValuesFrom <http://www.co-ode.org/ontologies/ont.owl#Claim>
                                                                        ] ,
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#describes> ;
                                                                          owl:someValuesFrom <http://www.co-ode.org/ontologies/ont.owl#Drug>
                                                                        ] ,
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty <http://www.co-ode.org/ontologies/ont.owl#isPartOf> ;
                                                                          owl:someValuesFrom <http://www.co-ode.org/ontologies/ont.owl#Label>
                                                                        ] .


###  http://www.co-ode.org/ontologies/ont.owl#MissingEvidenceConflict
<http://www.co-ode.org/ontologies/ont.owl#MissingEvidenceConflict> rdf:type owl:Class ;
                                                                   rdfs:subClassOf <http://www.co-ode.org/ontologies/ont.owl#Conflict> .


###  http://www.co-ode.org/ontologies/ont.owl#MissingTextualEvidence
<http://www.co-ode.org/ontologies/ont.owl#MissingTextualEvidence> rdf:type owl:Class ;
                                                                  rdfs:subClassOf <http://www.co-ode.org/ontologies/ont.owl#Evidence> .


###  http://www.co-ode.org/ontologies/ont.owl#NMRA_Advertising_Guideline
<http://www.co-ode.org/ontologies/ont.owl#NMRA_Advertising_Guideline> rdf:type owl:Class ;
                                                                      rdfs:subClassOf <http://www.co-ode.org/ontologies/ont.owl#RegulatoryGuideline> .


###  http://www.co-ode.org/ontologies/ont.owl#NMRA_Import_Control_Guideline
<http://www.co-ode.org/ontologies/ont.owl#NMRA_Import_Control_Guideline> rdf:type owl:Class ;
                                                                         rdfs:subClassOf <http://www.co-ode.org/ontologies/ont.owl#RegulatoryGuideline> .


###  http://www.co-ode.org/ontologies/ont.owl#NMRA_Labelling_Guideline
<http://www.co-ode.org/ontologies/ont.owl#NMRA_Labelling_Guideline> rdf:type owl:Class ;
