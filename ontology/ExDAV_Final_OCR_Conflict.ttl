#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( <http://www.co-ode.org/ontologies/ont.owl#AuthenticDrug>
                <http://www.co-ode.org/ontologies/ont.owl#CounterfeitDrug>
                <http://www.co-ode.org/ontologies/ont.owl#SuspiciousDrug>
                <http://www.co-ode.org/ontologies/ont.owl#UnverifiedDrug>
              )
] .


#################################################################
#    Rules
#################################################################

<http://www.w3.org/2002/07/c> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<http://www.w3.org/2002/07/e> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<http://www.w3.org/2002/07/v> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<http://www.w3.org/2002/07/a> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<http://www.w3.org/2002/07/d> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<http://www.w3.org/2002/07/sec> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<d> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<c> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<http://www.w3.org/2002/07/s> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

[ <http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> "true"^^xsd:boolean ;
   rdfs:comment "Classifies a drug as suspicious if any conflict is detected" ;
   rdfs:label "R1_Drug_With_Conflict_Is_Suspicious" ;
   rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#classPredicate> <http://www.co-ode.org/ontologies/ont.owl#DrugProduct> ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <http://www.w3.org/2002/07/d>
                                                     ] ;
                                           rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                      rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                  <http://www.w3.org/2003/11/swrl#propertyPredicate> <http://www.co-ode.org/ontologies/ont.owl#hasConflict> ;
                                                                  <http://www.w3.org/2003/11/swrl#argument1> <http://www.w3.org/2002/07/d> ;
                                                                  <http://www.w3.org/2003/11/swrl#argument2> <http://www.w3.org/2002/07/c>
                                                                ] ;
                                                      rdf:rest rdf:nil
                                                    ]
                                         ] ;
   <http://www.w3.org/2003/11/swrl#head> rdf:nil
 ] .

[ <http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> "true"^^xsd:boolean ;
   rdfs:comment "" ;
   rdfs:label "Evidence-to-Conflict Rule" ;
   rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#classPredicate> <http://www.co-ode.org/ontologies/ont.owl#Evidence> ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <http://www.w3.org/2002/07/e>
                                                     ] ;
                                           rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                      rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                  <http://www.w3.org/2003/11/swrl#propertyPredicate> <http://www.co-ode.org/ontologies/ont.owl#arisesFrom> ;
                                                                  <http://www.w3.org/2003/11/swrl#argument1> <http://www.w3.org/2002/07/c> ;
                                                                  <http://www.w3.org/2003/11/swrl#argument2> <http://www.w3.org/2002/07/e>
                                                                ] ;
                                                      rdf:rest rdf:nil
                                                    ]
                                         ] ;
   <http://www.w3.org/2003/11/swrl#head> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#classPredicate> <http://www.co-ode.org/ontologies/ont.owl#Conflict> ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <http://www.w3.org/2002/07/c>
                                                     ] ;
                                           rdf:rest rdf:nil
                                         ]
 ] .

[ <http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> "true"^^xsd:boolean ;
   rdfs:comment "VisualEvidence(?e)" ;
