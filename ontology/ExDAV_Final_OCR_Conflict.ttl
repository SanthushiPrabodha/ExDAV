###  http://www.co-ode.org/ontologies/ont.owl#NMRA_ADV_SEC_5
<http://www.co-ode.org/ontologies/ont.owl#NMRA_ADV_SEC_5> rdf:type owl:NamedIndividual ,
                                                                   <http://www.co-ode.org/ontologies/ont.owl#RegulatorySection> ;
                                                          <http://www.co-ode.org/ontologies/ont.owl#description> "General principles prohibiting false, misleading, exaggerated or unverifiable advertising claims; requires factual accuracy, balance, substantiation, and ethical presentation" ;
                                                          <http://www.co-ode.org/ontologies/ont.owl#pageNumber> 5 ;
                                                          <http://www.co-ode.org/ontologies/ont.owl#sectionNumber> 5 .


###  http://www.co-ode.org/ontologies/ont.owl#NMRA_ADV_SEC_6
<http://www.co-ode.org/ontologies/ont.owl#NMRA_ADV_SEC_6> rdf:type owl:NamedIndividual ,
                                                                   <http://www.co-ode.org/ontologies/ont.owl#RegulatorySection> ;
                                                          <http://www.co-ode.org/ontologies/ont.owl#description> "Social responsibility requirements; prohibits fear-based messaging, abuse of public trust, inducement of anxiety, self-diagnosis, misuse of statistics, and psychological manipulation in advertisements" ;
                                                          <http://www.co-ode.org/ontologies/ont.owl#pageNumber> 8 ;
                                                          <http://www.co-ode.org/ontologies/ont.owl#sectionNumber> 6 .


###  http://www.co-ode.org/ontologies/ont.owl#NMRA_ADV_SEC_7
<http://www.co-ode.org/ontologies/ont.owl#NMRA_ADV_SEC_7> rdf:type owl:NamedIndividual ,
                                                                   <http://www.co-ode.org/ontologies/ont.owl#RegulatorySection> ;
                                                          <http://www.co-ode.org/ontologies/ont.owl#description> "Prohibited therapeutic claims including cure, prevention, diagnosis, immunity, anti-aging, brain enhancement, stress relief, or treatment of specified diseases unless explicitly approved by NMRA" ;
                                                          <http://www.co-ode.org/ontologies/ont.owl#pageNumber> 11 ;
                                                          <http://www.co-ode.org/ontologies/ont.owl#sectionNumber> 7 .


###  http://www.co-ode.org/ontologies/ont.owl#NMRA_ADV_SEC_8
<http://www.co-ode.org/ontologies/ont.owl#NMRA_ADV_SEC_8> rdf:type owl:NamedIndividual ,
                                                                   <http://www.co-ode.org/ontologies/ont.owl#RegulatorySection> ;
                                                          <http://www.co-ode.org/ontologies/ont.owl#description> "Product-related claims prohibiting misleading visuals and descriptions such as before-and-after images, false safety claims (e.g., 'no side effects'), improper natural or herbal claims, exaggerated novelty, and over-emphasis on origin" ;
                                                          <http://www.co-ode.org/ontologies/ont.owl#pageNumber> 12 ;
                                                          <http://www.co-ode.org/ontologies/ont.owl#sectionNumber> 8 .


