<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.w3.org/2002/07/owl#"
     xml:base="http://www.w3.org/2002/07/owl"
     xmlns:ont="http://www.co-ode.org/ontologies/ont.owl#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#">
    <Ontology/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled -->

    <AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.co-ode.org/ontologies/ont.owl#arisesFrom -->

    <ObjectProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#arisesFrom"/>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#assesses -->

    <ObjectProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#assesses">
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/ont.owl#AuthenticityAssesment"/>
        <rdfs:range rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Evidence"/>
    </ObjectProperty>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#assignedTo -->

    <ObjectProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#assignedTo"/>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#containsClaim -->

    <ObjectProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#containsClaim"/>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#derivedFrom -->

    <ObjectProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#derivedFrom"/>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#describes -->

    <ObjectProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#describes"/>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#detectedIn -->

    <ObjectProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#detectedIn"/>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#detectsConflict -->

    <ObjectProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#detectsConflict">
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/ont.owl#AuthenticityAssesment"/>
        <rdfs:range rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Conflict"/>
    </ObjectProperty>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#hasClaim -->

    <ObjectProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#hasClaim">
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Drug"/>
        <rdfs:range rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Claim"/>
    </ObjectProperty>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#hasConflict -->

    <ObjectProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#hasConflict">
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/ont.owl#AuthenticityAssesment"/>
        <rdfs:range rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Conflict"/>
    </ObjectProperty>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#hasDrug -->

    <ObjectProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#hasDrug">
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/ont.owl#AuthenticityAssesment"/>
        <rdfs:range rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Drug"/>
        <rdfs:range rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Evidence"/>
        <rdfs:range rdf:resource="http://www.co-ode.org/ontologies/ont.owl#RegulatoryStatus"/>
    </ObjectProperty>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#hasEvidence -->

    <ObjectProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#hasEvidence">
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Evidence"/>
        <rdfs:range rdf:resource="http://www.co-ode.org/ontologies/ont.owl#EvidenceSource"/>
    </ObjectProperty>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#hasImage -->

    <ObjectProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#hasImage">
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Drug"/>
        <rdfs:range rdf:resource="http://www.co-ode.org/ontologies/ont.owl#DrugImage"/>
    </ObjectProperty>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#hasLabel -->

    <ObjectProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#hasLabel">
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Drug"/>
        <rdfs:range rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Label"/>
    </ObjectProperty>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#hasLabelElement -->

    <ObjectProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#hasLabelElement">
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Label"/>
        <rdfs:range rdf:resource="http://www.co-ode.org/ontologies/ont.owl#LabelElement"/>
    </ObjectProperty>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#hasRegulatoryStatus -->

    <ObjectProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#hasRegulatoryStatus">
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Drug"/>
        <rdfs:range rdf:resource="http://www.co-ode.org/ontologies/ont.owl#RegulatoryStatus"/>
    </ObjectProperty>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#hasSource -->

    <ObjectProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#hasSource">
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Evidence"/>
        <rdfs:range rdf:resource="http://www.co-ode.org/ontologies/ont.owl#EvidenceSource"/>
    </ObjectProperty>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#hasVisualEvidence -->

    <ObjectProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#hasVisualEvidence">
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Claim"/>
        <rdfs:range rdf:resource="http://www.co-ode.org/ontologies/ont.owl#DrugImage"/>
    </ObjectProperty>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#isClaimOn -->

    <ObjectProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#isClaimOn"/>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#isLabelOf -->

    <ObjectProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#isLabelOf"/>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#isPartOf -->

    <ObjectProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#isPartOf"/>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#mayCause -->

    <ObjectProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#mayCause"/>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#producesStatus -->

    <ObjectProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#producesStatus">
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Drug"/>
        <rdfs:range rdf:resource="http://www.co-ode.org/ontologies/ont.owl#RegulatoryStatus"/>
    </ObjectProperty>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#provides -->

    <ObjectProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#provides"/>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#refersToGuideline -->

    <ObjectProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#refersToGuideline">
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/ont.owl#AuthenticityAssesment"/>
        <rdfs:range rdf:resource="http://www.co-ode.org/ontologies/ont.owl#RegulatoryGuideline"/>
    </ObjectProperty>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#support -->

    <ObjectProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#support"/>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#treats -->

    <ObjectProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#treats">
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Drug"/>
        <rdfs:range rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Disease"/>
    </ObjectProperty>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#triggeredBy -->

    <ObjectProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#triggeredBy"/>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#usedIn -->

    <ObjectProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#usedIn"/>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#usesEvidence -->

    <ObjectProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#usesEvidence">
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Drug"/>
        <rdfs:range rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Evidence"/>
    </ObjectProperty>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#violates -->

    <ObjectProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#violates"/>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#violatesGuideline -->

    <ObjectProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#violatesGuideline">
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Drug"/>
        <rdfs:range rdf:resource="http://www.co-ode.org/ontologies/ont.owl#RegulatorySection"/>
    </ObjectProperty>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#violatesSection -->

    <ObjectProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#violatesSection">
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Claim"/>
        <rdfs:range rdf:resource="http://www.co-ode.org/ontologies/ont.owl#RegulatorySection"/>
    </ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.co-ode.org/ontologies/ont.owl#authenticityClass -->

    <DatatypeProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#authenticityClass">
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/ont.owl#DrugImage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </DatatypeProperty>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#claimText -->

    <DatatypeProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#claimText"/>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#claimType -->

    <DatatypeProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#claimType"/>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#confidenceScore -->

    <DatatypeProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#confidenceScore">
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Evidence"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </DatatypeProperty>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#description -->

    <DatatypeProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#description"/>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#dosageForm -->

    <DatatypeProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#dosageForm">
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Drug"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </DatatypeProperty>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#drugName -->

    <DatatypeProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#drugName">
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Drug"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </DatatypeProperty>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#evidenceType -->

    <DatatypeProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#evidenceType">
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Evidence"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </DatatypeProperty>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#imageID -->

    <DatatypeProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#imageID">
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/ont.owl#DrugImage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </DatatypeProperty>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#imagePath -->

    <DatatypeProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#imagePath">
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/ont.owl#DrugImage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </DatatypeProperty>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#packageSize -->

    <DatatypeProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#packageSize">
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Drug"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </DatatypeProperty>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#pageNumber -->

    <DatatypeProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#pageNumber"/>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#riskScore -->

    <DatatypeProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#riskScore">
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/ont.owl#AuthenticityAssesment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </DatatypeProperty>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#sectionNumber -->

    <DatatypeProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#sectionNumber"/>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#strength -->

    <DatatypeProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#strength">
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Drug"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </DatatypeProperty>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#verdict -->

    <DatatypeProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#verdict">
        <rdfs:domain rdf:resource="http://www.co-ode.org/ontologies/ont.owl#AuthenticityAssesment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.co-ode.org/ontologies/ont.owl#AuthenticityAssesment -->

    <Class rdf:about="http://www.co-ode.org/ontologies/ont.owl#AuthenticityAssesment">
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://www.co-ode.org/ontologies/ont.owl#hasDrug"/>
                <someValuesFrom rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Drug"/>
            </Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://www.co-ode.org/ontologies/ont.owl#producesStatus"/>
                <someValuesFrom rdf:resource="http://www.co-ode.org/ontologies/ont.owl#RegulatoryStatus"/>
            </Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://www.co-ode.org/ontologies/ont.owl#usesEvidence"/>
                <someValuesFrom rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Evidence"/>
            </Restriction>
        </rdfs:subClassOf>
    </Class>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#Cardiovascular_Disease -->

    <Class rdf:about="http://www.co-ode.org/ontologies/ont.owl#Cardiovascular_Disease">
        <rdfs:subClassOf rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Disease"/>
    </Class>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#Claim -->

    <Class rdf:about="http://www.co-ode.org/ontologies/ont.owl#Claim">
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://www.co-ode.org/ontologies/ont.owl#isClaimOn"/>
                <someValuesFrom rdf:resource="http://www.co-ode.org/ontologies/ont.owl#LabelElement"/>
            </Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://www.co-ode.org/ontologies/ont.owl#mayCause"/>
                <someValuesFrom rdf:resource="http://www.co-ode.org/ontologies/ont.owl#RegulatoryViolation"/>
            </Restriction>
        </rdfs:subClassOf>
    </Class>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#Compliant -->

    <Class rdf:about="http://www.co-ode.org/ontologies/ont.owl#Compliant">
        <rdfs:subClassOf rdf:resource="http://www.co-ode.org/ontologies/ont.owl#RegulatoryStatus"/>
        <disjointWith rdf:resource="http://www.co-ode.org/ontologies/ont.owl#NonCompliant"/>
    </Class>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#Conflict -->

    <Class rdf:about="http://www.co-ode.org/ontologies/ont.owl#Conflict">
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://www.co-ode.org/ontologies/ont.owl#arisesFrom"/>
                <someValuesFrom rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Evidence"/>
            </Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://www.co-ode.org/ontologies/ont.owl#detectedIn"/>
                <someValuesFrom rdf:resource="http://www.co-ode.org/ontologies/ont.owl#AuthenticityAssesment"/>
            </Restriction>
        </rdfs:subClassOf>
    </Class>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#Dermatological_Disease -->

    <Class rdf:about="http://www.co-ode.org/ontologies/ont.owl#Dermatological_Disease">
        <rdfs:subClassOf rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Disease"/>
    </Class>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#Disease -->

    <Class rdf:about="http://www.co-ode.org/ontologies/ont.owl#Disease"/>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#Drug -->

    <Class rdf:about="http://www.co-ode.org/ontologies/ont.owl#Drug"/>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#DrugImage -->

    <Class rdf:about="http://www.co-ode.org/ontologies/ont.owl#DrugImage"/>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#Evidence -->

    <Class rdf:about="http://www.co-ode.org/ontologies/ont.owl#Evidence">
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://www.co-ode.org/ontologies/ont.owl#derivedFrom"/>
                <someValuesFrom rdf:resource="http://www.co-ode.org/ontologies/ont.owl#EvidenceSource"/>
            </Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://www.co-ode.org/ontologies/ont.owl#support"/>
                <someValuesFrom rdf:resource="http://www.co-ode.org/ontologies/ont.owl#AuthenticityAssesment"/>
            </Restriction>
        </rdfs:subClassOf>
    </Class>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#EvidenceSource -->

    <Class rdf:about="http://www.co-ode.org/ontologies/ont.owl#EvidenceSource">
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://www.co-ode.org/ontologies/ont.owl#provides"/>
                <someValuesFrom rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Evidence"/>
            </Restriction>
        </rdfs:subClassOf>
    </Class>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#Label -->

    <Class rdf:about="http://www.co-ode.org/ontologies/ont.owl#Label">
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://www.co-ode.org/ontologies/ont.owl#hasLabelElement"/>
                <someValuesFrom rdf:resource="http://www.co-ode.org/ontologies/ont.owl#LabelElement"/>
            </Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://www.co-ode.org/ontologies/ont.owl#isLabelOf"/>
                <someValuesFrom rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Drug"/>
            </Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://www.co-ode.org/ontologies/ont.owl#usedIn"/>
                <someValuesFrom rdf:resource="http://www.co-ode.org/ontologies/ont.owl#AuthenticityAssesment"/>
            </Restriction>
        </rdfs:subClassOf>
    </Class>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#LabelElement -->

    <Class rdf:about="http://www.co-ode.org/ontologies/ont.owl#LabelElement">
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://www.co-ode.org/ontologies/ont.owl#containsClaim"/>
                <someValuesFrom rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Claim"/>
            </Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://www.co-ode.org/ontologies/ont.owl#describes"/>
                <someValuesFrom rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Drug"/>
            </Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://www.co-ode.org/ontologies/ont.owl#isPartOf"/>
                <someValuesFrom rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Label"/>
            </Restriction>
        </rdfs:subClassOf>
    </Class>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#NMRA_Advertising_Guideline -->

    <Class rdf:about="http://www.co-ode.org/ontologies/ont.owl#NMRA_Advertising_Guideline">
