    <!-- http://www.co-ode.org/ontologies/ont.owl#RegulatoryStatus -->

    <Class rdf:about="http://www.co-ode.org/ontologies/ont.owl#RegulatoryStatus">
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://www.co-ode.org/ontologies/ont.owl#assignedTo"/>
                <someValuesFrom rdf:resource="http://www.co-ode.org/ontologies/ont.owl#AuthenticityAssesment"/>
            </Restriction>
        </rdfs:subClassOf>
    </Class>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#RegulatoryViolation -->

    <Class rdf:about="http://www.co-ode.org/ontologies/ont.owl#RegulatoryViolation">
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://www.co-ode.org/ontologies/ont.owl#triggeredBy"/>
                <someValuesFrom rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Conflict"/>
            </Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://www.co-ode.org/ontologies/ont.owl#violates"/>
                <someValuesFrom rdf:resource="http://www.co-ode.org/ontologies/ont.owl#RegulatoryRequirement"/>
            </Restriction>
        </rdfs:subClassOf>
    </Class>
    


