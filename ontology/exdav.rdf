    </NamedIndividual>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#Claim_Product_Misleading -->

    <NamedIndividual rdf:about="http://www.co-ode.org/ontologies/ont.owl#Claim_Product_Misleading">
        <rdf:type rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Claim"/>
