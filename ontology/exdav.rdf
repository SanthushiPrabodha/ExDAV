    <!-- http://www.co-ode.org/ontologies/ont.owl#NMRA_ADV_SEC_5 -->

    <NamedIndividual rdf:about="http://www.co-ode.org/ontologies/ont.owl#NMRA_ADV_SEC_5">
        <rdf:type rdf:resource="http://www.co-ode.org/ontologies/ont.owl#RegulatorySection"/>
        <ont:description>General principles prohibiting false, misleading, exaggerated or unverifiable advertising claims; requires factual accuracy, balance, substantiation, and ethical presentation</ont:description>
        <ont:pageNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</ont:pageNumber>
        <ont:sectionNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</ont:sectionNumber>
    </NamedIndividual>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#NMRA_ADV_SEC_6 -->

    <NamedIndividual rdf:about="http://www.co-ode.org/ontologies/ont.owl#NMRA_ADV_SEC_6">
        <rdf:type rdf:resource="http://www.co-ode.org/ontologies/ont.owl#RegulatorySection"/>
        <ont:description>Social responsibility requirements; prohibits fear-based messaging, abuse of public trust, inducement of anxiety, self-diagnosis, misuse of statistics, and psychological manipulation in advertisements</ont:description>
        <ont:pageNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">8</ont:pageNumber>
        <ont:sectionNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">6</ont:sectionNumber>
    </NamedIndividual>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#NMRA_ADV_SEC_7 -->

    <NamedIndividual rdf:about="http://www.co-ode.org/ontologies/ont.owl#NMRA_ADV_SEC_7">
        <rdf:type rdf:resource="http://www.co-ode.org/ontologies/ont.owl#RegulatorySection"/>
        <ont:description>Prohibited therapeutic claims including cure, prevention, diagnosis, immunity, anti-aging, brain enhancement, stress relief, or treatment of specified diseases unless explicitly approved by NMRA</ont:description>
        <ont:pageNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">11</ont:pageNumber>
        <ont:sectionNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">7</ont:sectionNumber>
    </NamedIndividual>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#NMRA_ADV_SEC_8 -->

    <NamedIndividual rdf:about="http://www.co-ode.org/ontologies/ont.owl#NMRA_ADV_SEC_8">
        <rdf:type rdf:resource="http://www.co-ode.org/ontologies/ont.owl#RegulatorySection"/>
        <ont:description>Product-related claims prohibiting misleading visuals and descriptions such as before-and-after images, false safety claims (e.g., &apos;no side effects&apos;), improper natural or herbal claims, exaggerated novelty, and over-emphasis on origin</ont:description>
        <ont:pageNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">12</ont:pageNumber>
        <ont:sectionNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">8</ont:sectionNumber>
    </NamedIndividual>
    


