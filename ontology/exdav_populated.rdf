<owl:NamedIndividual rdf:about="http://www.co-ode.org/ontologies/ont.owl#Claim_Fear_Inducing">
  <rdf:type rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Claim"/>
  <ont.:claimText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fear-based or anxiety-inducing messaging encouraging self-diagnosis</ont.:claimText>
  <ont.:claimType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Social</ont.:claimType>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="http://www.co-ode.org/ontologies/ont.owl#Claim_General_Misleading">
  <rdf:type rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Claim"/>
  <ont.:claimText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">False, exaggerated or unverifiable claims violating general principles</ont.:claimText>
  <ont.:claimType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">General</ont.:claimType>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="http://www.co-ode.org/ontologies/ont.owl#Claim_Product_Misleading">
  <rdf:type rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Claim"/>
  <ont.:claimText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Claims such as 'no side effects', '100% natural', or before-after visuals</ont.:claimText>
  <ont.:claimType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Product</ont.:claimType>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="http://www.co-ode.org/ontologies/ont.owl#Claim_Therapeutic_Prohibited">
  <rdf:type rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Claim"/>
  <ont.:claimText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Claims to cure or prevent disease without NMRA approval</ont.:claimText>
  <ont.:claimType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Therapeutic</ont.:claimType>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="http://www.co-ode.org/ontologies/ont.owl#Evidence_Visual_Check">
  <rdf:type rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Evidence"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="http://www.co-ode.org/ontologies/ont.owl#Evidence_Label_Analysis">
  <rdf:type rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Evidence"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="http://www.co-ode.org/ontologies/ont.owl#NMRA_ADV_SEC_5">
  <rdf:type rdf:resource="http://www.co-ode.org/ontologies/ont.owl#RegulatorySection"/>
  <ont.:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">General principles prohibiting false, misleading, exaggerated or unverifiable advertising claims; requires factual accuracy, balance, substantiation, and ethical presentation</ont.:description>
  <ont.:pageNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</ont.:pageNumber>
  <ont.:sectionNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</ont.:sectionNumber>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="http://www.co-ode.org/ontologies/ont.owl#NMRA_ADV_SEC_6">
  <rdf:type rdf:resource="http://www.co-ode.org/ontologies/ont.owl#RegulatorySection"/>
  <ont.:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Social responsibility requirements; prohibits fear-based messaging, abuse of public trust, inducement of anxiety, self-diagnosis, misuse of statistics, and psychological manipulation in advertisements</ont.:description>
  <ont.:pageNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">8</ont.:pageNumber>
  <ont.:sectionNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">6</ont.:sectionNumber>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="http://www.co-ode.org/ontologies/ont.owl#NMRA_ADV_SEC_7">
  <rdf:type rdf:resource="http://www.co-ode.org/ontologies/ont.owl#RegulatorySection"/>
  <ont.:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Prohibited therapeutic claims including cure, prevention, diagnosis, immunity, anti-aging, brain enhancement, stress relief, or treatment of specified diseases unless explicitly approved by NMRA</ont.:description>
  <ont.:pageNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">11</ont.:pageNumber>
  <ont.:sectionNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">7</ont.:sectionNumber>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="http://www.co-ode.org/ontologies/ont.owl#NMRA_ADV_SEC_8">
  <rdf:type rdf:resource="http://www.co-ode.org/ontologies/ont.owl#RegulatorySection"/>
  <ont.:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Product-related claims prohibiting misleading visuals and descriptions such as before-and-after images, false safety claims (e.g., 'no side effects'), improper natural or herbal claims, exaggerated novelty, and over-emphasis on origin</ont.:description>
  <ont.:pageNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">12</ont.:pageNumber>
  <ont.:sectionNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">8</ont.:sectionNumber>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="http://www.co-ode.org/ontologies/ont.owl#RegulatoryRequirement_Labeling"/>

